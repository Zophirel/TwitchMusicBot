// Prisma schema for MusicBot (skeleton)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum SongStatus {
  QUEUED
  PLAYING
  PLAYED
  REJECTED
}

model SongRequest {
  id             String     @id @default(cuid())
  twitchUser     String
  query          String
  createdAt      DateTime   @default(now())
  youtubeVideoId String
  youtubeTitle   String
  status         SongStatus @default(QUEUED)
}

model Settings {
  id            Int      @id @default(1)
  autoplay      Boolean  @default(false)
  allowAnyone   Boolean  @default(true)
  whitelistJson String   @default("[]")
  blacklistJson String   @default("[]")
  updatedAt     DateTime @updatedAt
}

model TwitchAuth {
  id           Int      @id @default(1)
  accessToken  String
  refreshToken String
  scope        String?
  expiresAt    DateTime
  updatedAt    DateTime @updatedAt
}
